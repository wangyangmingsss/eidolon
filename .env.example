# === Network selection ===
# Either "testnet" or "mainnet".
OG_NETWORK=mainnet

# === 0G endpoints (override only if 0G publishes new ones) ===
# Leave blank to use the defaults from packages/sdk/src/constants.ts
OG_RPC_URL=
OG_STORAGE_INDEXER=
OG_COMPUTE_MARKETPLACE=

# === Wallet (NEVER COMMIT REAL VALUES) ===
DEPLOYER_PRIVATE_KEY=0x_PUT_YOUR_KEY_IN_DOT_ENV_LOCAL
DEPLOYER_ADDRESS=0x_FILL_AFTER_GENERATING_KEY

# === Oracle wallet (separate key for the oracle service) ===
ORACLE_PRIVATE_KEY=0x_PUT_YOUR_KEY_IN_DOT_ENV_LOCAL
ORACLE_ADDRESS=0x_FILL_AFTER_GENERATING_KEY

# === Contract addresses (filled by Doc 2's deploy script) ===
SOUL_NFT_ADDRESS=0xa300aF5F0E20d974F20E55E71BB4229aE0A404be
MARKETPLACE_ADDRESS=0xC084835B0e3cd8B344Fa5Feb6429960EBbC830Ac
ORACLE_REGISTRY_ADDRESS=0x3cf95f18E9D49Dd88E69872D5C24e75a982e93FC

# === LLM model (filled automatically by verify script in §1.7) ===
LLM_MODEL_PROVIDER=
LLM_MODEL_NAME=

# === Frontend (Vercel will set these in production) ===
NEXT_PUBLIC_OG_NETWORK=mainnet
